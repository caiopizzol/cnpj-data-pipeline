# CNPJ Data Pipeline Configuration

# Database (PostgreSQL via Docker on port 5435)
DATABASE_URL=postgres://postgres:postgres@localhost:5435/cnpj

# Processing
BATCH_SIZE=500000
TEMP_DIR=./temp

# Downloads (parallel)
DOWNLOAD_WORKERS=4

# Network
RETRY_ATTEMPTS=3
RETRY_DELAY=5
CONNECT_TIMEOUT=30
READ_TIMEOUT=300

# Cleanup
KEEP_DOWNLOADED_FILES=false

# API Server Configuration
API_PORT=8080 # Port for the API server
API_WORKERS=2 # Number of worker processes for the API server
API_AUTH_ENABLED=false # Set to True to enable API token authentication
API_TOKEN=<SEU_TOKEN_AQUI> # Replace with your actual token

# Ngrok key (optional, for exposing local server)
NGROK_ENABLED=false # Set to true to enable ngrok tunneling
NGROK_URL=<SEU-DOMINIO-PUBLIC.ngrok-free.dev> # Replace with your actual ngrok URL
NGROK_AUTH_TOKEN=<SEU_NGROK_AUTH_TOKEN_AQUI> # Replace with your actual ngrok auth token
